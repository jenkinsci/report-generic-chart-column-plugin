    "id": "FINAL_UP_CUTTING_OK",
    "comments": [
      "combination:LONG_UP_CUT_OK or SHORT_UP_CUT_OK or IMMEDIATE_UP_OK",
      "four parameters",
      "cut, immediate threshold, short time threshold, long time threshold",
      "eg: FINAL_UP_CUTTING_OK  2 5 5 5"
    ],
