[
  {
    "id": "IMMEDIATE_CALC",
    "comments": [
      "computing the change (in %) against previous run ",
      "(L1/(L0/100)-100)"
    ],
    "equations": [
      {
        "name": "len",
        "equation": [
          "MN"
        ],
        "descriptions": [
          {"condition": "/*RESULT*/ <= 0 ","description": ["warning, not enough data values for safe calculation (MN). Should be at lest 1."]}
        ]
      },
      {
        "name": "main",
        "equation": [
          "(L1/(L0/100)-100)"
        ],
        "descriptions": [
          {"condition": "true","description": ["The relative difference between this (L0) and previous (L1, from total of MN) is: /*RESULT*/%"]}
        ]
      }
    ]
  },
  {
      "id": "SHORT_CALC",
    "comments": [
      "computing the change (in %) against previous runs (is using avg of previous points)",
      "(avg(..L1)/(L0/100)-100)"
    ],
    "equations": [
      {
        "name": "len",
        "equation": [
          "MN-1"
        ],
        "descriptions": [
        {"condition": "/*RESULT*/ <= 0 ","description": ["warning, not enough data values for safe calculation (MN). Should be at lest 2."]}
      ]
      },{
        "name": "avg",
        "equation": [
          "avg(..L1)"
        ]
      },{
        "name": "main",
        "equation": [
          "(/*avg*//(L0/100)-100)"
        ],
        "descriptions": [
          {"condition": "true","description": ["The /*avg*/ is the avg of: ..L1"]},
          {"condition": "true","description": ["The relative difference between this (L0) and avg(/*avg*/) of previous(/*len*/) values is: /*RESULT*/%"]}
        ]
      }
    ]
  },



  {
    "id": "IMMEDIATE_UP_OK",
    "comments": [
      "checking whether drop (in %) against previous run was not bigger then threshold",
      "one parameter, threshold number",
      "eg: IMMEDIATE_UP_OK 5"
    ],
    "equations": [
      {
        "name": "immediate_calc",
        "equation": [
          "IMMEDIATE_CALC"
        ]
      },
      {
        "name": "main",
        "equation": [
          "threshold=/*1*/;",
          "  /*immediate_calc*/ >  threshold"
        ],
        "descriptions": [
          { "condition": "true","description": ["This calculation is ensuring, that 'more is better', on immediate scale with tolerance of /*1*/%."]},
          { "condition": "true","description": ["The result,  whether drop (in %) against previous run was not not bigger then threshold is:"]},
          { "condition": "/*RESULT*/ eq true  ","description": ["The /*immediate_calc*/% is bigger then threshold /*1*/%, that is ok."]},
          { "condition": "/*RESULT*/ eq false ","description": ["The /*immediate_calc*/% is lower or equal to  threshold /*1*/%, that is bad."]}
      ]
      }
    ]
  },
  {
    "id": "IMMEDIATE_DOWN_OK",
    "comments": [
      "checking whether rise (in %) against previous run was not bigger then threshold",
      "one parameter, threshold number",
      "eg: IMMEDIATE_DOWN_OK 5"
    ],
    "equations": [
      {
        "name": "immediate_calc",
        "equation": [
          "IMMEDIATE_CALC"
        ]
      },
      {
        "name": "main",
        "equation": [
          "threshold=/*1*/;",
          "  /*immediate_calc*/ < -threshold"
        ],
        "descriptions": [
          { "condition": "true","description": ["This calculation is ensuring, that 'less is better', on immediate scale with tolerance of /*1*/%."]},
          { "condition": "true","description": ["The result, whether rise (in %) against previous run was not bigger then threshold is:"]},
          { "condition": "/*RESULT*/ eq true  ","description": ["The /*immediate_calc*/% is lower then threshold -/*1*/%, that is ok."]},
          { "condition": "/*RESULT*/ eq false ","description": ["The /*immediate_calc*/% is bigger or equal to  threshold -/*1*/%, that is bad."]}
        ]
      }
    ]
  },
